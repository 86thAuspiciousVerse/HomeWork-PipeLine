#!/usr/bin/env python
# -*- coding: utf-8 -*-
"""hw-exec —— HomeWork-PipeLine 唯一自写执行器 CLI（DESIGN.md §11.2 / §11.2.0 / §11.2.1）。

职责边界（§11.2.0）：
  - hw-exec **只跑子进程 + 机器校验**（确定性，零 LLM）。
  - 代码生成 / 改码 = hw-orchestrator（LLM subagent）；hw-exec 永不"修代码"。
  - hw-exec **不判 B 级**：tier=B 的 node 标 passed_pending_b_judge，真过交 P6
    auditor subagent 判。
  - hw-exec **不直接写 facts.json**（P0-3）：commit-facts 只落
    <run_dir>/execution/facts_patch_<node>.json 分片，由 P7 唯一合并写者收编。

五个 verb（全部严格 JSON 输出到 stdout；exit 0=执行器自身正常，非0=执行器自身故障）：
    prepare      —— 准备 execution 子目录与空子状态 execution/state.json
    run-node     —— subprocess.run([<venv python>, "code/<node>.py"], cwd=run-dir)
                    抓 stdout/stderr/exitcode → 读 contract_<node>.yaml →
                    按 check 原子校验产物 → 留痕钩子 → 回写 node.status
    verify-node  —— 不跑子进程，仅对已有产物按 contract check 原子复检（auditor 复用）
    commit-facts —— 把 passed node 的 facts_patch（数字+产物 digest+trace_png 路径）
                    落 execution/facts_patch_<node>.json 分片
    status       —— 返回 run_dir 下执行器子状态 JSON

通用参数：--python <作业venv python.exe> --run-dir <.homework/run_<id>> --node <node>
run-node 另支持 --force-adopt-default（DESIGN.md §11.2.1：give_up 后有默认产物时
主 agent 调此旗标注 source:default_trade，诚信标注）。

node.status 枚举（§11.2.1）：
    pending | running | retriable | passed | passed_pending_b_judge |
    failed | given_up | supply_needed
  - supply_needed：某 check 依赖外部资源（如高德 key 未配）→ 不计 retry 预算、
    不假装配 key、转 supply_halt 回写 state.yaml。

重试预算（§11.2.1 P1-3）：per node {cold:1, fix:3}；同一 node 同一 failed_check
连续2次相同 → detected_loop → give_up。give_up 后由主 agent 据两档处理，执行器
只回写 status=given_up。

term2img 留痕（§11.2.1）：run-node 末尾留可被调用的钩子点。v1 集成方式：
  /term2img skill 由主 agent 串（执行器内只落 trace 路径占位 + facts_patch.trace_png
  字段）；执行器不直接调 skill（skill 是 LLM 工具，非确定性进程）。
  钩子失败不判 node 挂，仅记 term2img.ok=false。

依赖（DESIGN.md §11.2.2）：hw-exec 自身用 plugin-venv 的 Python（shebang 指向），
pydantic/pyarrow/pandas 装在 plugin-venv，与作业 venv 完全隔离。yaml 优先 PyYAML
（同环境），缺失退回 JSON 落盘（沿用 orchestrator_state.py 约定）。
"""

# 标准库
import argparse
import datetime as _dt
import json
import os
import subprocess
import sys
from pathlib import Path
from typing import Any, Dict, List, Optional # noqa: E402

# 把本文件所在目录加入 sys.path 以 import executor.verifiers 子系统
# （无 pip 包，纯路径 import；与 orchestrator_state.py 同目录约定）。
_HERE = Path(__file__).resolve().parent
if str(_HERE) not in sys.path:
    sys.path.insert(0, str(_HERE))

# verifier 子系统（同目录 executor/verifiers/）
from executor.verifiers import (  # noqa: E402
    load_yaml, dump_yaml, atomic_write,
    run_assert, run_tool, run_presence,
)
from executor.verifiers.check_atoms import (  # noqa: E402
    run_check_atom, file_digest, verdict,
)


# ---------------------------------------------------------------------------
# 执行器子状态文件（execution/state.json —— state.yaml 的 EXECUTOR.substate_ref 指针内联）
# ---------------------------------------------------------------------------

NODE_STATUS = (
    "pending", "running", "retriable", "passed",
    "passed_pending_b_judge", "failed", "given_up", "supply_needed",
)
RETRY_BUDGET = {"cold": 1, "fix": 3}  # DESIGN.md §11.2.1 per node


def _exec_state_path(run_dir: Path) -> Path:
    """执行器子状态文件：execution/state.json（orchestrator_state.py 的 substate_ref 指针）。"""
    return run_dir / "execution" / "state.json"


def _load_exec_state(run_dir: Path) -> Dict[str, Any]:
    """读执行器子状态；不存在则返回默认骨架。"""
    p = _exec_state_path(run_dir)
    if not p.exists():
        return {"version": "0.1", "nodes": {}, "updated_at": None}
    try:
        return json.loads(p.read_text(encoding="utf-8"))
    except Exception:
        return {"version": "0.1", "nodes": {}, "updated_at": None, "_corrupt": True}


def _save_exec_state(run_dir: Path, state: Dict[str, Any]) -> None:
    """原子写执行器子状态（execution/state.json）。"""
    state["updated_at"] = _dt.datetime.now().isoformat()
    atomic_write(_exec_state_path(run_dir), json.dumps(state, ensure_ascii=False, indent=2))


def _node_state(exec_state: Dict[str, Any], node: str) -> Dict[str, Any]:
    """取某 node 子状态（不存在则建默认 pending）。"""
    nodes = exec_state.setdefault("nodes", {})
    if node not in nodes:
        nodes[node] = {
            "status": "pending",
            "attempts": 0,
            "cold_used": 0,
            "fix_used": 0,
            "last_error": None,
            "last_failed_check": None,
            "failed_check_streak": 0,   # 同 check 连续相同次数（detected_loop 用）
            "facts_patch_path": None,
            "trace_png": None,
            "term2img_ok": None,
            "verdicts": [],
        }
    return nodes[node]


# ---------------------------------------------------------------------------
# contract 读取（run-dir/artifacts/contract_<node>.yaml；方案权产生，本层只读只校验）
# ---------------------------------------------------------------------------

def _load_contract(run_dir: Path, node: str) -> Dict[str, Any]:
    """读 contract_<node>.yaml；不存在 → 执行器自身故障（非0退出由调用方处理）。"""
    p = run_dir / "artifacts" / f"contract_{node}.yaml"
    if not p.exists():
        raise FileNotFoundError(f"contract 不存在: {p}（应由 P4 方案权产生）")
    return load_yaml(p)


def _contract_tier(contract: Dict[str, Any]) -> str:
    """tier=A 走 check 原子集；tier=B 无机器 contract，只跑 + 留痕。"""
    return str(contract.get("tier", "A")).upper()


# ---------------------------------------------------------------------------
# check 执行：把 contract.artifacts[].checks + stdout_asserts + exit_must_be
# 摊平成 check 列表，统一走 check_atoms / runner 分派
# ---------------------------------------------------------------------------

def _flatten_checks(contract: Dict[str, Any], ctx: Dict[str, Any]) -> List[Dict[str, Any]]:
    """把 contract 内各类机器约束摊平成统一 check 列表。

    摊平来源：
      - contract.artifacts[].checks[] —— 对应产物的 row_count/col_set/...
      - contract.stdout_asserts[]     —— stdout_assert
      - contract.exit_must_be         —— exit_match（仅当显式给）
    每个 check 带 path 上下文（来自其所属 artifact）。
    """
    checks: List[Dict[str, Any]] = []
    for art in contract.get("artifacts", []) or []:
        art_path = art.get("path")
        for ck in art.get("checks", []) or []:
            ck2 = dict(ck)
            if art_path and "path" not in ck2 and ck2.get("type") in (
                "row_count", "col_set", "col_range", "dup_key", "json_path",
                "file_exists", "file_size_min", "assert_expr",
            ):
                ck2["path"] = art_path
            checks.append(ck2)
    for sa in contract.get("stdout_asserts", []) or []:
        checks.append(dict(sa, type="stdout_assert"))
    if "exit_must_be" in contract:
        checks.append({"id": "exit_must", "type": "exit_match", "value": contract["exit_must_be"]})
    return checks


def _find_supply_needed(verdicts: List[Dict[str, Any]], contract: Dict[str, Any]) -> Optional[str]:
    """识别 supply_needed：某 check 标 supply_needed=True（外部资源缺，如 key 未配）。

    判定来源（DESIGN.md §11.2.1 supply_needed 语义）：
      - check 元数据带 supply_needed: true；或
      - contract.deps[].supply_needed 标该节点依赖外部 resource；或
      - stdout 含典型"key 未配置/认证失败"信号（保守：由调用方/主 agent 翻译，
        本执行器仅在 check 显式标注时判定，避免误判）。
    返回触发 check 的 id（无则 None），使回写 supply_halt 时可带 trigger: executor。
    """
    for v in verdicts:
        # check 携带 supply_needed 元字段（运行期通过 verdict 透传）
        if v.get("supply_needed") is True:
            return v.get("id")
    # contract 顶层 deps 声明
    for dep in contract.get("deps", []) or []:
        if dep.get("supply_needed") is True and dep.get("node") is None:
            return dep.get("id", "contract_dep")
    return None


# ---------------------------------------------------------------------------
# run-node 主体
# ---------------------------------------------------------------------------

def _run_node(args: argparse.Namespace) -> int:
    run_dir = Path(args.run_dir)
    node = args.node
    if not node:
        return _emit_self_error("run-node 缺 --node")

    # 标记 running（幂等：可从任何前置状态重入）
    exec_state = _load_exec_state(run_dir)
    ns = _node_state(exec_state, node)
    prev_status = ns["status"]
    ns["status"] = "running"
    _save_exec_state(run_dir, exec_state)

    contract: Dict[str, Any]
    try:
        contract = _load_contract(run_dir, node)
    except FileNotFoundError as e:
        ns["status"] = "failed"
        ns["last_error"] = str(e)
        _save_exec_state(run_dir, exec_state)
        return _emit({"node": node, "status": "failed", "self_error": str(e)})

    tier = _contract_tier(contract)

    # force-adopt-default：give_up 后有默认产物，主 agent 调此旗标注 default_trade
    if args.force_adopt_default:
        da = contract.get("default_artifact") or {}
        probe_ctx = {"run_dir": run_dir, "stdout": ns.get("force_stdout", ""),
                     "exit_code": 0, "node_artifact": da.get("path")}
        # 默认产物 file_exists 即过（DESIGN.md §11.2.1 P2-7）
        v = run_check_atom({"id": "default_exists", "type": "file_exists",
                            "path": da.get("path", "")}, probe_ctx)
        ok = v["passed"]
        ns["status"] = "passed" if ok else "failed"
        ns["last_error"] = None if ok else v.get("detail")
        ns["verdicts"] = [v]
        ns.setdefault("source", "default_trade")
        _save_exec_state(run_dir, exec_state)
        return _emit({"node": node, "status": ns["status"],
                      "source": "default_trade", "verdicts": [v]})

    # 真跑子进程：subprocess.run([<venv python>, "code/<node>.py"], cwd=run-dir)
    script = run_dir / "code" / f"{node}.py"
    if not script.exists():
        ns["status"] = "failed"
        ns["last_error"] = f"作业代码不存在: {script}"
        _save_exec_state(run_dir, exec_state)
        return _emit({"node": node, "status": "failed",
                      "self_error": ns["last_error"]})

    python = args.python
    if not python:
        ns["status"] = "failed"
        ns["last_error"] = "run-node 缺 --python（作业 venv python.exe）"
        _save_exec_state(run_dir, exec_state)
        return _emit({"node": node, "status": "failed", "self_error": ns["last_error"]})

    runtime = contract.get("runtime", {}) or {}
    wall_s = int(runtime.get("wall_s", 300))
    cmd = [python, str(script)]
    try:
        proc = subprocess.run(
            cmd, cwd=str(run_dir),
            capture_output=True, text=True, timeout=wall_s,
        )
        stdout, stderr, exit_code = proc.stdout, proc.stderr, proc.returncode
    except subprocess.TimeoutExpired as e:
        ns["status"] = "failed"
        ns["last_error"] = f"节点超时（wall_s={wall_s}）: {e}"
        ns["attempts"] += 1
        _bump_attempt(ns, "fix")
        _save_exec_state(run_dir, exec_state)
        return _emit({"node": node, "status": "failed", "self_error": ns["last_error"]})
    except FileNotFoundError as e:
        ns["status"] = "failed"
        ns["last_error"] = f"venv python 不可用: {e}"
        _save_exec_state(run_dir, exec_state)
        return _emit({"node": node, "status": "failed", "self_error": ns["last_error"]})

    ctx = {"run_dir": run_dir, "stdout": stdout, "stderr": stderr,
           "exit_code": exit_code, "node_artifact": None}

    # 校验产物：tier=B 无机器 contract → 直接标 passed_pending_b_judge（真过交 P6）
    if tier != "A":
        ns["status"] = "passed_pending_b_judge"
        ns["verdicts"] = [verdict("tier_b", "skip", True,
                                  "tier=B 无机器 contract，真过交 P6 auditor")]
        _term2img_hook(run_dir, node, ns, stdout)
        _save_exec_state(run_dir, exec_state)
        return _emit({"node": node, "status": ns["status"],
                      "exit_code": exit_code, "verdicts": ns["verdicts"]})

    # tier=A：按 check 原子校验
    checks = _flatten_checks(contract, ctx)
    verdicts: List[Dict[str, Any]] = []
    for ck in checks:
        # DESIGN §4 + §11.3.1：type=assert/tool/presence 走对应 runner；其余 check 原子走 check_atoms
        ctype = ck.get("type")
        if ctype == "assert":
            v = run_assert(ck, ctx)
        elif ctype == "tool":
            v = run_tool(ck, ctx)
        elif ctype == "presence":
            v = run_presence(ck, ctx)
        else:
            v = run_check_atom(ck, ctx)
        # 透传 check 元字段（如 supply_needed 标注）到 verdict
        if ck.get("supply_needed"):
            v["supply_needed"] = True
        verdicts.append(v)

    failed = [v for v in verdicts if not v["passed"]]

    # 识别 supply_needed（外部资源缺，不计 retry）
    supply_id = _find_supply_needed(verdicts, contract)
    if supply_id is not None:
        ns["status"] = "supply_needed"
        ns["verdicts"] = verdicts
        ns["last_error"] = f"supply_needed by {supply_id}（转 supply_halt，不计 retry）"
        ns["supply_trigger_id"] = supply_id
        _term2img_hook(run_dir, node, ns, stdout)
        _save_exec_state(run_dir, exec_state)
        return _emit({"node": node, "status": "supply_needed",
                      "supply_trigger_id": supply_id, "verdicts": verdicts})

    if not failed:
        ns["status"] = "passed"
        ns["verdicts"] = verdicts
        ns["last_error"] = None
        _term2img_hook(run_dir, node, ns, stdout)
        _save_exec_state(run_dir, exec_state)
        return _emit({"node": node, "status": "passed",
                      "exit_code": exit_code, "verdicts": verdicts})

    # 有失败：记录失败 check 连续相同（detected_loop 判定）
    failed_ids = sorted(v["id"] for v in failed)
    last_failed_key = ns.get("last_failed_check")
    if last_failed_key is not None and last_failed_key == failed_ids:
        ns["failed_check_streak"] = ns.get("failed_check_streak", 0) + 1
    else:
        ns["failed_check_streak"] = 1
    ns["last_failed_check"] = failed_ids

    ns["attempts"] += 1
    ns["verdicts"] = verdicts
    ns["last_error"] = "; ".join(f"{v['id']}: {v.get('detail','')}" for v in failed)

    # detected_loop：同一 failed_check 连续2次相同 → give_up（DESIGN.md §11.2.1）
    if ns["failed_check_streak"] >= 2:
        ns["status"] = "given_up"
        ns["last_error"] = "detected_loop: 同一 failed_check 连续2次相同 → give_up"
        _term2img_hook(run_dir, node, ns, stdout)
        _save_exec_state(run_dir, exec_state)
        return _emit({"node": node, "status": "given_up", "verdicts": verdicts})

    # 重试预算：cold 1 次 + fix 3 次。超 fix 上限 → give_up
    if _bump_attempt(ns, "fix"):
        ns["status"] = "given_up"
        ns["last_error"] = "fix 预算耗尽（cold:1+fix:3）→ give_up"
        _term2img_hook(run_dir, node, ns, stdout)
        _save_exec_state(run_dir, exec_state)
        return _emit({"node": node, "status": "given_up", "verdicts": verdicts})

    ns["status"] = "retriable"
    _term2img_hook(run_dir, node, ns, stdout)
    _save_exec_state(run_dir, exec_state)
    return _emit({"node": node, "status": "retriable",
                  "exit_code": exit_code, "verdicts": verdicts})


def _bump_attempt(ns: Dict[str, Any], phase: str) -> bool:
    """按 cold/fix 维度记账；返回 True=预算耗尽应 give_up。

    冷启（cold:1）与修码重跑（fix:3）分维度计数。第一次跑算 cold，其后算 fix。
    """
    if ns.get("cold_used", 0) < RETRY_BUDGET["cold"]:
        ns["cold_used"] = ns.get("cold_used", 0) + 1
        return False
    ns["fix_used"] = ns.get("fix_used", 0) + 1
    return ns["fix_used"] > RETRY_BUDGET["fix"]


def _term2img_hook(run_dir: Path, node: str, ns: Dict[str, Any], stdout: str) -> None:
    """term2img 留痕钩子点（DESIGN.md §11.2.1）。

    v1 集成方式（注释必清）：/term2img skill 由主 agent 串（skill 是 LLM 工具，
    非确定性进程，执行器内不直接调）。执行器只落 trace 路径占位 + facts_patch.trace
    _png 字段，并把 hook 结果写进 ns['trace_png']/['term2img_ok']。
    失败不判 node 挂，仅记 term2img.ok=false。

    路径约定（DESIGN.md §11.2.2 + orchestrator_state §11.5）：
        execution/traces/<node>__attempt<n>.png
    """
    attempt = ns.get("fix_used", 0) + ns.get("cold_used", 0)
    trace_dir = run_dir / "execution" / "traces"
    trace_dir.mkdir(parents=True, exist_ok=True)
    # 路径约定（DESIGN.md §11.2.2 + orchestrator_state §11.5）：
    #   execution/traces/<node>__attempt<n>.png
    # 执行器仅落 run_dir 相对路径占位；真正 PNG 由 /term2img skill 渲染并替换占位。
    ns["trace_png"] = f"execution/traces/{node}__attempt{max(attempt, 0)}.png"
    # 钩子本身不渲染图（skill 是 LLM 工具、非确定性进程，执行器不直接调）；
    # ok=None 表示"尚未由主 agent 串完"，主 agent 串好 /term2img 后回写 true。
    ns["term2img_ok"] = None


# ---------------------------------------------------------------------------
# verify-node：不跑子进程，仅对已有产物按 contract check 原子复检（auditor 复用）
# ---------------------------------------------------------------------------

def _verify_node(args: argparse.Namespace) -> int:
    run_dir = Path(args.run_dir)
    node = args.node
    if not node:
        return _emit_self_error("verify-node 缺 --node")
    try:
        contract = _load_contract(run_dir, node)
    except FileNotFoundError as e:
        return _emit_self_error(str(e))
    ctx = {"run_dir": run_dir, "stdout": args.stdout or "", "exit_code": int(args.exit or 0),
           "node_artifact": args.artifact}
    checks = _flatten_checks(contract, ctx)
    verdicts: List[Dict[str, Any]] = []
    for ck in checks:
        ctype = ck.get("type")
        if ctype == "assert":
            v = run_assert(ck, ctx)
        elif ctype == "tool":
            v = run_tool(ck, ctx)
        elif ctype == "presence":
            v = run_presence(ck, ctx)
        else:
            v = run_check_atom(ck, ctx)
        verdicts.append(v)
    passed = all(v["passed"] for v in verdicts) if verdicts else True
    return _emit({"node": node, "tier": _contract_tier(contract),
                  "passed": passed, "verdicts": verdicts})


# ---------------------------------------------------------------------------
# commit-facts：落 facts_patch_<node>.json 分片（绝不直接写 facts.json，P0-3）
# ---------------------------------------------------------------------------

def _commit_facts(args: argparse.Namespace) -> int:
    run_dir = Path(args.run_dir)
    node = args.node
    if not node:
        return _emit_self_error("commit-facts 缺 --node")
    exec_state = _load_exec_state(run_dir)
    ns = _node_state(exec_state, node)
    # 仅 passed / passed_pending_b_judge 可提交 facts_patch
    if ns["status"] not in ("passed", "passed_pending_b_judge"):
        return _emit_self_error(
            f"node.status={ns['status']} 不可 commit-facts（仅 passed/passed_pending_b_judge 可）"
        )

    try:
        contract = _load_contract(run_dir, node)
    except FileNotFoundError as e:
        return _emit_self_error(str(e))

    # 收集产物 digest（流式 sha256，大文件不全量入内存）
    artifacts: Dict[str, Any] = {}
    for art in contract.get("artifacts", []) or []:
        ap = art.get("path")
        if not ap:
            continue
        ap_abs = run_dir / ap if not os.path.isabs(ap) else Path(ap)
        entry: Dict[str, Any] = {"path": ap}
        if ap_abs.exists() and ap_abs.is_file():
            try:
                entry["sha256"] = file_digest(ap_abs)
                entry["size_bytes"] = ap_abs.stat().st_size
            except Exception as e:  # noqa: BLE001
                entry["digest_error"] = str(e)
        else:
            entry["exists"] = False
        # 从该产物 checks 通过的 verdict 里抽可机计数字想象 facts.metrics（保守：失败结点不抽）
        entry["checks_passed"] = [
            v["id"] for v in ns.get("verdicts", [])
            if v.get("passed") and any(
                ck.get("path") == ap for ck in _flatten_checks(contract, {"run_dir": run_dir, "stdout": "", "exit_code": 0})
                if ck.get("id") == v["id"]
            )
        ]
        artifacts[ap] = entry

    facts_patch: Dict[str, Any] = {
        "node": node,
        "status": ns["status"],
        "tier": _contract_tier(contract),
        "source": ns.get("source", "ai_generated"),  # default_trade 时主 agent 调 force-adopt 已置
        "artifacts": artifacts,
        "trace_png": ns.get("trace_png"),
        "term2img_ok": ns.get("term2img_ok"),
        "verdicts": ns.get("verdicts", []),
        "committed_at": _dt.datetime.now().isoformat(),
    }

    patch_path = run_dir / "execution" / f"facts_patch_{node}.json"
    atomic_write(patch_path, json.dumps(facts_patch, ensure_ascii=False, indent=2))
    ns["facts_patch_path"] = str(patch_path.relative_to(run_dir))
    _save_exec_state(run_dir, exec_state)
    return _emit({"node": node, "facts_patch_path": str(patch_path.relative_to(run_dir)),
                  "facts_patch": facts_patch})


# ---------------------------------------------------------------------------
# prepare：建 execution 子目录与空 execution/state.json
# ---------------------------------------------------------------------------

def _prepare(args: argparse.Namespace) -> int:
    run_dir = Path(args.run_dir)
    (run_dir / "execution" / "traces").mkdir(parents=True, exist_ok=True)
    state = _load_exec_state(run_dir)
    _save_exec_state(run_dir, state)
    return _emit({"prepared": True,
                 "run_dir": str(run_dir),
                 "exec_state": "execution/state.json",
                 "retry_budget": RETRY_BUDGET})


# ---------------------------------------------------------------------------
# status：返回 run-dir 下执行器子状态 JSON
# ---------------------------------------------------------------------------

def _status(args: argparse.Namespace) -> int:
    run_dir = Path(args.run_dir)
    exec_state = _load_exec_state(run_dir)
    nodes = exec_state.get("nodes", {})
    summary = {
        "run_dir": str(run_dir),
        "updated_at": exec_state.get("updated_at"),
        "nodes": {
            n: {
                "status": s.get("status"),
                "attempts": s.get("attempts"),
                "cold_used": s.get("cold_used"),
                "fix_used": s.get("fix_used"),
                "last_error": s.get("last_error"),
                "last_failed_check": s.get("last_failed_check"),
                "failed_check_streak": s.get("failed_check_streak"),
                "facts_patch_path": s.get("facts_patch_path"),
                "trace_png": s.get("trace_png"),
                "term2img_ok": s.get("term2img_ok"),
            }
            for n, s in nodes.items()
        },
    }
    return _emit(summary)


# ---------------------------------------------------------------------------
# JSON 输出工具（严格 JSON 到 stdout；exit 0=执行器自身正常，非0=执行器自身故障）
# ---------------------------------------------------------------------------

def _emit(payload: Dict[str, Any]) -> int:
    """正常输出：严格 JSON，exit 0。"""
    print(json.dumps(payload, ensure_ascii=False, default=str))
    return 0


def _emit_self_error(msg: str) -> int:
    """执行器自身故障：JSON 错误体 + exit 非0。"""
    print(json.dumps({"self_error": msg}, ensure_ascii=False))
    return 1


# ---------------------------------------------------------------------------
# argparse 装配
# ---------------------------------------------------------------------------

def _build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="hw-exec", description="HomeWork-PipeLine 小执行器 CLI")
    sub = p.add_subparsers(dest="verb", required=True)

    def common(sp: argparse.ArgumentParser) -> None:
        sp.add_argument("--python", default=None, help="作业 venv 的 python.exe（run-node 用）")
        sp.add_argument("--run-dir", required=True, help=".homework/run_<id> 目录")
        sp.add_argument("--node", default=None, help="DAG 节点名")

    sp = sub.add_parser("prepare")
    common(sp)
    sp.set_defaults(func=_prepare)

    sp = sub.add_parser("run-node")
    common(sp)
    sp.add_argument("--force-adopt-default", action="store_true",
                    help="give_up 后有默认产物时主 agent 调此旗标 source:default_trade")
    sp.set_defaults(func=_run_node)

    sp = sub.add_parser("verify-node")
    common(sp)
    sp.add_argument("--stdout", default="", help="复检用 stdout（不跑子进程）")
    sp.add_argument("--exit", default="0", help="复检用 exit_code")
    sp.add_argument("--artifact", default=None, help="复检目标产物路径")
    sp.set_defaults(func=_verify_node)

    sp = sub.add_parser("commit-facts")
    common(sp)
    sp.set_defaults(func=_commit_facts)

    sp = sub.add_parser("status")
    sp.add_argument("--run-dir", required=True)
    sp.set_defaults(func=_status)
    return p


def main(argv: Optional[List[str]] = None) -> int:
    parser = _build_parser()
    args = parser.parse_args(argv)
    try:
        return int(args.func(args))
    except KeyboardInterrupt:
        print(json.dumps({"self_error": "interrupted"}, ensure_ascii=False))
        return 1
    except Exception as e:  # noqa: BLE001 — 执行器自身故障
        print(json.dumps({"self_error": f"{type(e).__name__}: {e}"}, ensure_ascii=False))
        return 1


if __name__ == "__main__":
    raise SystemExit(main())